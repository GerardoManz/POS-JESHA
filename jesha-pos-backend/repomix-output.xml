  iva             Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  folioFiscal     String?       // UUID del SAT — llega del PAC
  xmlUrl          String?
  pdfUrl          String?
  estado          EstadoFactura @default(FACTURADA)
  timbradaEn      DateTime?
  creadaEn        DateTime      @default(now())

  venta   Venta   @relation(fields: [ventaId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
}

// ══════════════════════════════
//  AUDITORÍA
//  Registra TODA acción importante del sistema
// ══════════════════════════════

model Auditoria {
  id           Int      @id @default(autoincrement())
  usuarioId    Int?
  sucursalId   Int?
  accion       String   // "CREAR_VENTA" | "CANCELAR_VENTA" | "EDITAR_PRODUCTO"
  modulo       String   // "ventas" | "inventario" | "caja" | "usuarios"
  referencia   String?  // "VTA-0042"
  valorAntes   Json?    // snapshot antes del cambio
  valorDespues Json?    // snapshot después del cambio
  ip           String?
  creadoEn     DateTime @default(now())

  usuario  Usuario?  @relation(fields: [usuarioId], references: [id])
  sucursal Sucursal? @relation(fields: [sucursalId], references: [id])
}
