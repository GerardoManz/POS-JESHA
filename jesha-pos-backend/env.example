# ════════════════════════════════════════════════════════════════════
#  JESHA POS — Variables de entorno
#  Copia este archivo como .env y llena los valores reales
#  NUNCA subas el .env real a GitHub
# ════════════════════════════════════════════════════════════════════

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/jesha_db"

# Entorno: development | production
NODE_ENV=development

# Secreto para firmar tokens JWT (mínimo 64 caracteres aleatorios)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar_por_secreto_real_de_64_caracteres_minimo

# Puerto del servidor (Railway lo asigna automáticamente)
PORT=3000

# Llave de FacturAPI (sandbox = sk_test_..., producción = sk_live_...)
FACTURAPI_KEY=sk_test_tu_llave_aqui

# URL del frontend en producción (para CORS)
FRONTEND_URL=https://tudominio.com

# URL de ngrok si la necesitas para pruebas
# NGROK_URL=https://tu-url.ngrok-free.dev
