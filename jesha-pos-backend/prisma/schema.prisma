// ═══════════════════════════════════════════════════════════════════
//  JESHA POS — Schema Prisma FINAL UNIFICADO
//  Base de datos: PostgreSQL 18
//  Fusión de Schema ACTUAL + Schema V2
//  DEPARTAMENTOS: Herramientas, Plomería, Electricidad, Pintura, 
//                Gas, Limpieza, Seguridad, Construcción, SERVICIOS
//  ¡LISTA PARA IMPLEMENTAR!
// ═══════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════
//  ENUMS
// ═══════════════════════════════

enum Rol {
  SUPERADMIN
  ADMIN_SUCURSAL
  EMPLEADO
  PRECIOS
}

enum EstadoVenta {
  COMPLETADA
  CANCELADA
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
}

enum EstadoCotizacion {
  PENDIENTE
  CONVERTIDA
  VENCIDA
  CANCELADA
}

enum EstadoPedido {
  BORRADOR
  PENDIENTE
  ACTIVO
  BLOQUEADO
  EJECUTADO
  CANCELADO
}

enum EstadoOrdenCompra {
  ENVIADO
  RECIBIDO_PARCIAL
  RECIBIDO
  CANCELADO
}

enum EstadoFactura {
  DISPONIBLE
  FACTURADA
  VENCIDA
  CANCELADA
}

enum TipoMovimientoInventario {
  ENTRADA_COMPRA
  SALIDA_VENTA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  DEVOLUCION_ENTRADA
  DEVOLUCION_SALIDA
}

enum TipoMovimientoCaja {
  APERTURA
  VENTA
  DEVOLUCION
  AJUSTE
  CIERRE
}

enum TipoPromocion {
  BUEN_FIN
  HOT_SALE
  MANUAL
}

enum AlcancePromocion {
  PRODUCTO
  CATEGORIA
  SUCURSAL
}

enum EstadoAlerta {
  PENDIENTE
  VISTA
  RESUELTA
}

// ═══════════════════════════════
//  SUCURSAL
// ═══════════════════════════════

model Sucursal {
  id           Int      @id @default(autoincrement())
  nombre       String
  direccion    String?
  telefono     String?
  codigoPostal String   // requerido para CFDI lugar_expedicion
  activa       Boolean  @default(true)
  creadaEn     DateTime @default(now())

  usuarios      Usuario[]
  inventarios   InventarioSucursal[]
  ventas        Venta[]
  cotizaciones  Cotizacion[]
  pedidos       Pedido[]
  ordenesCompra OrdenCompra[]
  turnosCaja    TurnoCaja[]
  promociones   Promocion[]
  alertasStock  AlertaStock[]
  auditorias    Auditoria[]
}

// ═══════════════════════════════
//  USUARIO
// ═══════════════════════════════

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  username     String   @unique
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  sucursalId   Int?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])

  ventas         Venta[]
  cotizaciones   Cotizacion[]
  turnosCaja     TurnoCaja[]
  pedidos        Pedido[]
  movimientos    MovimientoInventario[]
  auditorias     Auditoria[]
}

// ═══════════════════════════════
//  CLIENTE
// ═══════════════════════════════

model Cliente {
  id                 Int      @id @default(autoincrement())
  nombre             String
  apodo              String?  
  rfc                String?  @unique
  telefono           String?
  email              String?
  codigoPostalFiscal String?
  regimenFiscal      String?
  razonSocial        String?        
  usoCfdi            String?        
  tipo               String   @default("REGULAR")
  limiteCredito      Decimal  @default(0) @db.Decimal(12,2)
  activo             Boolean  @default(true)                  
  notas              String?
  creadoEn           DateTime @default(now())

  ventas       Venta[]
  cotizaciones Cotizacion[]
  pedidos      Pedido[]
  facturas     FacturaCfdi[]
}

// ═══════════════════════════════
//  DEPARTAMENTO (NUEVO)
//  Nivel alto de categorización
// ═══════════════════════════════

model Departamento {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  icono     String?
  activo    Boolean   @default(true)
  creadoEn  DateTime  @default(now())

  categorias Categoria[]
}

// ═══════════════════════════════
//  CATEGORIA
//  Modificado: Ahora con relación a Departamento
// ═══════════════════════════════

model Categoria {
  id              Int    @id @default(autoincrement())
  departamentoId  Int
  nombre          String
  descripcion     String?

  creadoEn        DateTime @default(now())

  departamento Departamento @relation(fields: [departamentoId], references: [id])
  productos    Producto[]
  promociones  Promocion[]

  @@unique([departamentoId, nombre])
}

// ═══════════════════════════════
//  PROVEEDOR
// ═══════════════════════════════

model Proveedor {
  id            Int      @id @default(autoincrement())
  nombreOficial String
  alias         String?
  telefono      String?
  celular       String?
  email         String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())

  productos     ProveedorProducto[]
  ordenesCompra OrdenCompra[]
}

// ═══════════════════════════════
//  PROVEEDOR-PRODUCTO
//  Precio costo por proveedor por producto
// ═══════════════════════════════

model ProveedorProducto {
  id              Int     @id @default(autoincrement())
  proveedorId     Int
  productoId      Int
  codigoProveedor String?
  precioCosto     Decimal @db.Decimal(10, 2)
  activo          Boolean @default(true)

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])

  @@unique([proveedorId, productoId])
}

// ═══════════════════════════════
//  PRODUCTO
//  Modificado: Agrega codigoInterno, unidades SAT, costoPromedio
// ═══════════════════════════════

model Producto {
  id              Int      @id @default(autoincrement())
  
  // Identificación
  nombre          String
  codigoInterno   String   @unique      // NUEVO: diferente a código de barras
  codigoBarras    String?  @unique
  descripcion     String?

  // Imágenes
  imagenUrl       String?
  imagenOriginal  String?               // NUEVO: URL imagen original

  // Precios y Costos
  precioBase      Decimal  @db.Decimal(10, 2)     // BLINDADO
  costo           Decimal? @db.Decimal(10, 2)     // Costo último
  costoPromedio   Decimal? @db.Decimal(10, 2)     // NUEVO: Costo promedio ponderado

  // Unidades de Medida (NUEVO)
  unidadCompra    String?                         // ej: "caja"
  unidadVenta     String?                         // ej: "pza"
  factorConversion Decimal? @db.Decimal(10, 4)    // ej: 12

  // Claves SAT (NUEVO)
  claveSat        String?                         // 8 dígitos
  unidadSat       String?                         // código SAT

  // Relaciones
  categoriaId     Int
  departamentoId  Int?                            // NUEVO: opcional FK a departamento

  // Estado
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  categoria        Categoria          @relation(fields: [categoriaId], references: [id])
  inventarios      InventarioSucursal[]
  detallesVenta    DetalleVenta[]
  detallesCotizacion DetalleCotizacion[]
  detallesOrdenCompra DetalleOrdenCompra[]
  detallesPedido   DetallePedido[]
  proveedores      ProveedorProducto[]
  promociones      Promocion[]        @relation("PromocionProducto")
  movimientos      MovimientoInventario[]

  @@index([nombre])
  @@index([codigoInterno])
  @@index([codigoBarras])
}

// ═══════════════════════════════
//  INVENTARIO POR SUCURSAL
// ═══════════════════════════════

model InventarioSucursal {
  id                Int      @id @default(autoincrement())
  productoId        Int
  sucursalId        Int
  stockActual       Int      @default(0)
  stockMinimoAlerta Int      @default(5)
  stockMaximo       Int?
  actualizadoEn     DateTime @updatedAt

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([productoId, sucursalId])
  @@index([sucursalId])
  @@index([stockActual])
}

// ═══════════════════════════════
//  MOVIMIENTO INVENTARIO
//  Modificado: Agrega sucursalId, usuarioId e índices
// ═══════════════════════════════

model MovimientoInventario {
  id           Int                      @id @default(autoincrement())
  productoId   Int
  sucursalId   Int                      // NUEVO
  usuarioId    Int?                     // NUEVO: quién hizo el cambio
  tipo         TipoMovimientoInventario
  cantidad     Int
  stockAntes   Int
  stockDespues Int
  referencia   String?
  notas        String?
  creadoEn     DateTime @default(now())

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([sucursalId])
  @@index([usuarioId])
  @@index([tipo])
  @@index([creadoEn])
}

// ═══════════════════════════════
//  ALERTA DE STOCK BAJO
// ═══════════════════════════════

model AlertaStock {
  id          Int          @id @default(autoincrement())
  productoId  Int
  sucursalId  Int
  stockActual Int
  stockMinimo Int
  estado      EstadoAlerta @default(PENDIENTE)
  creadaEn    DateTime     @default(now())
  vistaEn     DateTime?

  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([productoId, sucursalId, estado])
}

// ═══════════════════════════════
//  TURNO DE CAJA
// ═══════════════════════════════

model TurnoCaja {
  id                  Int       @id @default(autoincrement())
  sucursalId          Int
  usuarioId           Int
  montoInicial        Decimal   @db.Decimal(10, 2)
  montoFinalDeclarado Decimal?  @db.Decimal(10, 2)
  montoCalculado      Decimal?  @db.Decimal(10, 2)
  diferencia          Decimal?  @db.Decimal(10, 2)
  abierto             Boolean   @default(true)
  abiertaEn           DateTime  @default(now())
  cerradaEn           DateTime?

  sucursal    Sucursal         @relation(fields: [sucursalId], references: [id])
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])
  ventas      Venta[]
  movimientos MovimientoCaja[]
}

model MovimientoCaja {
  id         Int                @id @default(autoincrement())
  turnoId    Int
  tipo       TipoMovimientoCaja
  monto      Decimal            @db.Decimal(10, 2)
  metodoPago MetodoPago?
  referencia String?
  notas      String?
  creadoEn   DateTime           @default(now())

  turno TurnoCaja @relation(fields: [turnoId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════
//  VENTA
// ═══════════════════════════════

model Venta {
  id            Int         @id @default(autoincrement())
  folio         String      @unique
  sucursalId    Int
  usuarioId     Int
  clienteId     Int?
  turnoId       Int?
  metodoPago    MetodoPago
  subtotal      Decimal     @db.Decimal(10, 2)
  descuento     Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  estado        EstadoVenta @default(COMPLETADA)

  tokenQr       String        @unique @default(uuid())
  facturaEstado EstadoFactura @default(DISPONIBLE)
  facturaLimite DateTime

  notas    String?
  creadaEn DateTime @default(now())

  sucursal     Sucursal       @relation(fields: [sucursalId], references: [id])
  usuario      Usuario        @relation(fields: [usuarioId], references: [id])
  cliente      Cliente?       @relation(fields: [clienteId], references: [id])
  turno        TurnoCaja?     @relation(fields: [turnoId], references: [id])
  detalles     DetalleVenta[]
  devoluciones Devolucion[]
  factura      FacturaCfdi?
}

model DetalleVenta {
  id             Int     @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  descuento      Decimal @default(0) @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  promocionId    Int?

  venta     Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto  Producto   @relation(fields: [productoId], references: [id])
  promocion Promocion? @relation(fields: [promocionId], references: [id])
}

// ═══════════════════════════════
//  DEVOLUCIÓN
// ═══════════════════════════════

model Devolucion {
  id                  Int      @id @default(autoincrement())
  ventaId             Int
  sucursalId          Int
  usuarioId           Int
  motivo              String
  reintegraInventario Boolean  @default(true)
  tipoReembolso       String
  montoReembolso      Decimal  @db.Decimal(10, 2)
  notas               String?
  creadaEn            DateTime @default(now())

  venta    Venta               @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  detalles DetalleDevolucion[]
}

model DetalleDevolucion {
  id             Int     @id @default(autoincrement())
  devolucionId   Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)

  devolucion Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════
//  COTIZACIÓN
// ═══════════════════════════════

model Cotizacion {
  id         Int              @id @default(autoincrement())
  folio      String           @unique
  sucursalId Int
  usuarioId  Int
  clienteId  Int?
  total      Decimal          @db.Decimal(10, 2)
  estado     EstadoCotizacion @default(PENDIENTE)
  venceEn    DateTime?
  notas      String?
  creadaEn   DateTime         @default(now())

  sucursal Sucursal            @relation(fields: [sucursalId], references: [id])
  usuario  Usuario             @relation(fields: [usuarioId], references: [id])
  cliente  Cliente?            @relation(fields: [clienteId], references: [id])
  detalles DetalleCotizacion[]
}

model DetalleCotizacion {
  id             Int     @id @default(autoincrement())
  cotizacionId   Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [productoId], references: [id])
}

// ═══════════════════════════════
//  PEDIDO (BITÁCORA)
// ═══════════════════════════════

model Pedido {
  id             Int          @id @default(autoincrement())
  folio          String       @unique
  sucursalId     Int
  usuarioId      Int
  clienteId      Int?
  estado         EstadoPedido @default(BORRADOR)
  totalEstimado  Decimal      @db.Decimal(10, 2)
  motivoBloqueo  String?
  notas          String?
  creadoEn       DateTime     @default(now())
  actualizadoEn  DateTime     @updatedAt

  sucursal Sucursal       @relation(fields: [sucursalId], references: [id])
  usuario  Usuario        @relation(fields: [usuarioId], references: [id])
  cliente  Cliente?       @relation(fields: [clienteId], references: [id])
  detalles DetallePedido[]
}

model DetallePedido {
  id             Int     @id @default(autoincrement())
  pedidoId       Int
  productoId     Int
  cantidad       Int
  precioAcordado Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

// ═══════════════════════════════
//  ORDEN DE COMPRA
// ═══════════════════════════════

model OrdenCompra {
  id            Int               @id @default(autoincrement())
  folio         String            @unique
  sucursalId    Int
  proveedorId   Int
  estado        EstadoOrdenCompra @default(ENVIADO)
  totalEstimado Decimal           @db.Decimal(10, 2)
  notas         String?
  creadaEn      DateTime          @default(now())
  recibidaEn    DateTime?

  sucursal  Sucursal             @relation(fields: [sucursalId], references: [id])
  proveedor Proveedor            @relation(fields: [proveedorId], references: [id])
  detalles  DetalleOrdenCompra[]
}

model DetalleOrdenCompra {
  id               Int     @id @default(autoincrement())
  ordenCompraId    Int
  productoId       Int
  cantidadPedida   Int
  cantidadRecibida Int     @default(0)
  precioCosto      Decimal @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto    Producto    @relation(fields: [productoId], references: [id])
}

// ═══════════════════════════════
//  PROMOCIÓN
// ═══════════════════════════════

model Promocion {
  id          Int              @id @default(autoincrement())
  nombre      String
  tipo        TipoPromocion
  alcance     AlcancePromocion
  descuento   Decimal          @db.Decimal(5, 2)
  activa      Boolean          @default(true)
  fechaInicio DateTime
  fechaFin    DateTime
  sucursalId  Int
  categoriaId Int?
  notas       String?
  creadaEn    DateTime         @default(now())

  sucursal      Sucursal       @relation(fields: [sucursalId], references: [id])
  categoria     Categoria?     @relation(fields: [categoriaId], references: [id])
  productos     Producto[]     @relation("PromocionProducto")
  detallesVenta DetalleVenta[]
}

// ═══════════════════════════════
//  FACTURA CFDI 4.0
// ═══════════════════════════════

model FacturaCfdi {
  id              Int           @id @default(autoincrement())
  ventaId         Int           @unique
  clienteId       Int
  rfcReceptor     String
  nombreReceptor  String
  cpReceptor      String
  regimenFiscal   String
  usoCfdi         String
  lugarExpedicion String
  subtotal        Decimal       @db.Decimal(10, 2)
  iva             Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  folioFiscal     String?
  xmlUrl          String?
  pdfUrl          String?
  estado          EstadoFactura @default(FACTURADA)
  timbradaEn      DateTime?
  creadaEn        DateTime      @default(now())

  venta   Venta   @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id])
}

// ═══════════════════════════════
//  AUDITORÍA
// ═══════════════════════════════

model Auditoria {
  id           Int      @id @default(autoincrement())
  usuarioId    Int?
  sucursalId   Int?
  accion       String
  modulo       String
  referencia   String?
  valorAntes   Json?
  valorDespues Json?
  ip           String?
  creadoEn     DateTime @default(now())

  usuario  Usuario?  @relation(fields: [usuarioId], references: [id])
  sucursal Sucursal? @relation(fields: [sucursalId], references: [id])

  @@index([usuarioId])
  @@index([modulo])
  @@index([accion])
  @@index([creadoEn])
}
