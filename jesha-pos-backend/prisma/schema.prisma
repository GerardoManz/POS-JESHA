generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AbonoBitacora {
  id         Int        @id @default(autoincrement())
  bitacoraId Int
  usuarioId  Int
  monto      Decimal    @db.Decimal(10, 2)
  metodoPago MetodoPago @default(EFECTIVO)
  notas      String?
  creadoEn   DateTime   @default(now())
  turnoId    Int?
  Bitacora   Bitacora   @relation(fields: [bitacoraId], references: [id], onDelete: Cascade)
  TurnoCaja  TurnoCaja? @relation(fields: [turnoId], references: [id])
  Usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([bitacoraId])
  @@index([turnoId])
}

model AbonoCompra {
  id            Int         @id @default(autoincrement())
  ordenCompraId Int
  usuarioId     Int
  monto         Decimal     @db.Decimal(10, 2)
  metodoPago    MetodoPago  @default(EFECTIVO)
  notas         String?
  creadoEn      DateTime    @default(now())
  OrdenCompra   OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  Usuario       Usuario     @relation(fields: [usuarioId], references: [id])

  @@index([ordenCompraId])
}

model AlertaStock {
  id          Int          @id @default(autoincrement())
  productoId  Int
  sucursalId  Int
  stockActual Decimal      @db.Decimal(10, 3)
  stockMinimo Decimal      @db.Decimal(10, 3)
  estado      EstadoAlerta @default(PENDIENTE)
  creadaEn    DateTime     @default(now())
  vistaEn     DateTime?
  resueltaEn  DateTime?
  turnoId     Int?
  Producto    Producto     @relation(fields: [productoId], references: [id])
  Sucursal    Sucursal     @relation(fields: [sucursalId], references: [id])
  TurnoCaja   TurnoCaja?   @relation(fields: [turnoId], references: [id])

  @@unique([productoId, sucursalId, turnoId])
  @@index([estado])
  @@index([productoId])
  @@index([sucursalId])
  @@index([turnoId])
}

model Auditoria {
  id           Int       @id @default(autoincrement())
  usuarioId    Int?
  sucursalId   Int?
  accion       String
  modulo       String
  referencia   String?
  valorAntes   Json?
  valorDespues Json?
  ip           String?
  creadoEn     DateTime  @default(now())
  Sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])
  Usuario      Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([accion])
  @@index([creadoEn])
  @@index([modulo])
  @@index([sucursalId])
  @@index([usuarioId])
}

model Bitacora {
  id              Int               @id @default(autoincrement())
  folio           String            @unique
  clienteId       Int?
  sucursalId      Int
  usuarioId       Int
  estado          EstadoBitacora    @default(ABIERTA)
  totalMateriales Decimal           @default(0) @db.Decimal(12, 2)
  totalAbonado    Decimal           @default(0) @db.Decimal(12, 2)
  saldoPendiente  Decimal           @default(0) @db.Decimal(12, 2)
  notas           String?
  creadaEn        DateTime          @default(now())
  actualizadoEn   DateTime
  cerradaEn       DateTime?
  titulo          String?
  descripcion     String?
  origen          OrigenBitacora    @default(MANUAL)
  saldoAlCerrar   Decimal?          @db.Decimal(12, 2)
  AbonoBitacora   AbonoBitacora[]
  Cliente         Cliente?          @relation(fields: [clienteId], references: [id])
  Sucursal        Sucursal          @relation(fields: [sucursalId], references: [id])
  Usuario         Usuario           @relation(fields: [usuarioId], references: [id])
  DetalleBitacora DetalleBitacora[]

  @@index([clienteId])
  @@index([estado])
  @@index([origen])
  @@index([sucursalId])
}

model Categoria {
  id             Int          @id @default(autoincrement())
  departamentoId Int
  nombre         String
  descripcion    String?
  creadoEn       DateTime     @default(now())
  Departamento   Departamento @relation(fields: [departamentoId], references: [id])
  Producto       Producto[]
  Promocion      Promocion[]

  @@unique([departamentoId, nombre])
}

model Cliente {
  id                 Int           @id @default(autoincrement())
  nombre             String
  apodo              String?
  rfc                String?       @unique
  telefono           String?
  email              String?       @unique
  codigoPostalFiscal String?
  regimenFiscal      String?
  razonSocial        String?
  usoCfdi            String?
  tipo               String        @default("REGULAR")
  limiteCredito      Decimal       @default(0) @db.Decimal(12, 2)
  saldoPendiente     Decimal       @default(0) @db.Decimal(12, 2)
  totalCreditoUsado  Decimal       @default(0) @db.Decimal(12, 2)
  activo             Boolean       @default(true)
  notas              String?
  creadoEn           DateTime      @default(now())
  Bitacora           Bitacora[]
  Cotizacion         Cotizacion[]
  FacturaCfdi        FacturaCfdi[]
  Pedido             Pedido[]
  Venta              Venta[]

  @@index([email])
  @@index([nombre])
  @@index([rfc])
}

model Cotizacion {
  id                Int                 @id @default(autoincrement())
  folio             String              @unique
  sucursalId        Int
  usuarioId         Int
  clienteId         Int?
  total             Decimal             @db.Decimal(10, 2)
  estado            EstadoCotizacion    @default(PENDIENTE)
  tipo              String              @default("PRODUCTOS")
  venceEn           DateTime?
  notas             String?
  creadaEn          DateTime            @default(now())
  Cliente           Cliente?            @relation(fields: [clienteId], references: [id])
  Sucursal          Sucursal            @relation(fields: [sucursalId], references: [id])
  Usuario           Usuario             @relation(fields: [usuarioId], references: [id])
  DetalleCotizacion DetalleCotizacion[]

  @@index([clienteId])
  @@index([estado])
  @@index([tipo])
}

model Departamento {
  id        Int         @id @default(autoincrement())
  nombre    String      @unique
  icono     String?
  activo    Boolean     @default(true)
  creadoEn  DateTime    @default(now())
  Categoria Categoria[]
}

model DetalleBitacora {
  id                   Int       @id @default(autoincrement())
  bitacoraId           Int
  productoId           Int?
  cantidad             Decimal   @db.Decimal(10, 3)
  precioUnitario       Decimal   @db.Decimal(10, 2)
  subtotal             Decimal   @db.Decimal(10, 2)
  notas                String?
  creadoEn             DateTime  @default(now())
  ventaId              Int?
  inventarioDescontado Boolean   @default(false)
  Bitacora             Bitacora  @relation(fields: [bitacoraId], references: [id], onDelete: Cascade)
  Producto             Producto? @relation(fields: [productoId], references: [id])
  Venta                Venta?    @relation(fields: [ventaId], references: [id])

  @@index([bitacoraId])
  @@index([ventaId])
}

model DetalleCotizacion {
  id             Int        @id @default(autoincrement())
  cotizacionId   Int
  productoId     Int?
  concepto       String?
  unidad         String?
  cantidad       Decimal    @db.Decimal(10, 3)
  precioUnitario Decimal    @db.Decimal(10, 2)
  descuento      Decimal    @default(0) @db.Decimal(10, 2)
  subtotal       Decimal    @db.Decimal(10, 2)
  Cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  Producto       Producto?  @relation(fields: [productoId], references: [id])
}

model DetalleDevolucion {
  id             Int        @id @default(autoincrement())
  devolucionId   Int
  productoId     Int
  cantidad       Decimal    @db.Decimal(10, 3)
  precioUnitario Decimal    @db.Decimal(10, 2)
  creadoEn       DateTime   @default(now())
  Devolucion     Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
  Producto       Producto   @relation(fields: [productoId], references: [id])
}

model DetalleOrdenCompra {
  id               Int         @id @default(autoincrement())
  ordenCompraId    Int
  productoId       Int
  cantidadPedida   Decimal     @db.Decimal(10, 3)
  cantidadRecibida Decimal     @default(0) @db.Decimal(10, 3)
  precioCosto      Decimal     @db.Decimal(10, 2)
  subtotalPedido   Decimal     @db.Decimal(10, 2)
  subtotalRecibido Decimal     @default(0) @db.Decimal(10, 2)
  OrdenCompra      OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  Producto         Producto    @relation(fields: [productoId], references: [id])
}

model DetallePedido {
  id             Int      @id @default(autoincrement())
  pedidoId       Int
  productoId     Int
  cantidad       Decimal  @db.Decimal(10, 3)
  precioAcordado Decimal  @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  Pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  Producto       Producto @relation(fields: [productoId], references: [id])
}

model DetalleVenta {
  id             Int        @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Decimal    @db.Decimal(10, 3)
  precioUnitario Decimal    @db.Decimal(10, 2)
  descuento      Decimal    @default(0) @db.Decimal(10, 2)
  subtotal       Decimal    @db.Decimal(10, 2)
  promocionId    Int?
  Producto       Producto   @relation(fields: [productoId], references: [id])
  Promocion      Promocion? @relation(fields: [promocionId], references: [id])
  Venta          Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)
}

model Devolucion {
  id                  Int                 @id @default(autoincrement())
  ventaId             Int
  sucursalId          Int
  usuarioId           Int
  motivo              String
  reintegraInventario Boolean             @default(true)
  tipoReembolso       String
  montoReembolso      Decimal             @db.Decimal(10, 2)
  notas               String?
  creadaEn            DateTime            @default(now())
  DetalleDevolucion   DetalleDevolucion[]
  Usuario             Usuario             @relation(fields: [usuarioId], references: [id])
  Venta               Venta               @relation(fields: [ventaId], references: [id], onDelete: Cascade)
}

model FacturaCfdi {
  id              Int           @id @default(autoincrement())
  ventaId         Int           @unique
  clienteId       Int?
  rfcReceptor     String
  nombreReceptor  String
  cpReceptor      String
  regimenFiscal   String
  usoCfdi         String
  emailReceptor   String?
  lugarExpedicion String
  subtotal        Decimal       @db.Decimal(10, 2)
  iva             Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  folioFiscal     String?
  facturapiId     String?
  xmlUrl          String?
  pdfUrl          String?
  estado          EstadoFactura @default(FACTURADA)
  timbradaEn      DateTime?
  creadaEn        DateTime      @default(now())
  Cliente         Cliente?      @relation(fields: [clienteId], references: [id])
  Venta           Venta         @relation(fields: [ventaId], references: [id], onDelete: Cascade)
}

model InventarioSucursal {
  id                Int      @id @default(autoincrement())
  productoId        Int
  sucursalId        Int
  stockActual       Decimal  @default(0) @db.Decimal(10, 3)
  stockMinimoAlerta Decimal  @default(5) @db.Decimal(10, 3)
  stockMaximo       Decimal? @db.Decimal(10, 3)
  actualizadoEn     DateTime
  Producto          Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  Sucursal          Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([productoId, sucursalId])
  @@index([stockActual])
  @@index([sucursalId])
}

model MovimientoCaja {
  id         Int                @id @default(autoincrement())
  turnoId    Int
  tipo       TipoMovimientoCaja
  monto      Decimal            @db.Decimal(10, 2)
  metodoPago MetodoPago?
  referencia String?
  notas      String?
  creadoEn   DateTime           @default(now())
  TurnoCaja  TurnoCaja          @relation(fields: [turnoId], references: [id], onDelete: Cascade)

  @@index([turnoId])
}

model MovimientoInventario {
  id                      Int                      @id @default(autoincrement())
  productoId              Int
  sucursalId              Int
  usuarioId               Int?
  tipo                    TipoMovimientoInventario
  cantidad                Decimal                  @db.Decimal(10, 3)
  stockAntes              Decimal                  @db.Decimal(10, 3)
  stockDespues            Decimal                  @db.Decimal(10, 3)
  referencia              String?
  notas                   String?
  creadoEn                DateTime                 @default(now())
  turnoId                 Int?
  stockMinimoEnEseMomento Decimal?                 @db.Decimal(10, 3)
  Producto                Producto                 @relation(fields: [productoId], references: [id], onDelete: Cascade)
  Sucursal                Sucursal                 @relation(fields: [sucursalId], references: [id])
  TurnoCaja               TurnoCaja?               @relation(fields: [turnoId], references: [id])
  Usuario                 Usuario?                 @relation(fields: [usuarioId], references: [id])

  @@index([creadoEn])
  @@index([productoId])
  @@index([sucursalId])
  @@index([tipo])
  @@index([turnoId])
  @@index([usuarioId])
}

model OrdenCompra {
  id                 Int                  @id @default(autoincrement())
  folio              String               @unique
  sucursalId         Int
  proveedorId        Int
  usuarioId          Int
  estado             EstadoOrdenCompra    @default(ENVIADO)
  totalEstimado      Decimal              @db.Decimal(10, 2)
  totalRecibido      Decimal              @default(0) @db.Decimal(10, 2)
  pagada             Boolean              @default(false)
  totalPagado        Decimal              @default(0) @db.Decimal(12, 2)
  notas              String?
  creadaEn           DateTime             @default(now())
  recibidaEn         DateTime?
  AbonoCompra        AbonoCompra[]
  DetalleOrdenCompra DetalleOrdenCompra[]
  Proveedor          Proveedor            @relation(fields: [proveedorId], references: [id])
  Sucursal           Sucursal             @relation(fields: [sucursalId], references: [id])
  Usuario            Usuario              @relation(fields: [usuarioId], references: [id])

  @@index([estado])
  @@index([proveedorId])
  @@index([sucursalId])
}

model Pedido {
  id            Int             @id @default(autoincrement())
  folio         String          @unique
  sucursalId    Int
  usuarioId     Int
  clienteId     Int?
  estado        EstadoPedido    @default(BORRADOR)
  totalEstimado Decimal         @db.Decimal(10, 2)
  motivoBloqueo String?
  notas         String?
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime
  DetallePedido DetallePedido[]
  Cliente       Cliente?        @relation(fields: [clienteId], references: [id])
  Sucursal      Sucursal        @relation(fields: [sucursalId], references: [id])
  Usuario       Usuario         @relation(fields: [usuarioId], references: [id])
}

model Producto {
  id                   Int                    @id @default(autoincrement())
  nombre               String
  codigoInterno        String                 @unique
  codigoBarras         String?                @unique
  descripcion          String?
  imagenUrl            String?
  imagenOriginal       String?
  precioBase           Decimal                @db.Decimal(10, 2)
  precioVenta          Decimal?               @db.Decimal(10, 2)
  costo                Decimal?               @db.Decimal(10, 2)
  costoPromedio        Decimal?               @db.Decimal(10, 2)
  precioMayoreo        Decimal?               @db.Decimal(10, 2)
  cantidadMinMayoreo   Int?                   @default(10)
  aplicaMayoreo        Boolean                @default(false)
  unidadCompra         String?
  unidadVenta          String?
  factorConversion     Decimal?               @db.Decimal(10, 4)
  claveSat             String?
  unidadSat            String?
  esGranel             Boolean                @default(false)
  margen               Decimal?               @db.Decimal(5, 2)
  tipoFacturaProv      String?                @default("NETO")
  costoSinIvaProveedor Decimal?               @db.Decimal(10, 2)
  categoriaId          Int
  activo               Boolean                @default(true)
  actualizadoEn        DateTime
  facturaLimite        DateTime?              @default(now())
  imagenPublicId       String?
  AlertaStock          AlertaStock[]
  DetalleBitacora      DetalleBitacora[]
  DetalleCotizacion    DetalleCotizacion[]
  DetalleDevolucion    DetalleDevolucion[]
  DetalleOrdenCompra   DetalleOrdenCompra[]
  DetallePedido        DetallePedido[]
  DetalleVenta         DetalleVenta[]
  InventarioSucursal   InventarioSucursal[]
  MovimientoInventario MovimientoInventario[]
  Categoria            Categoria              @relation(fields: [categoriaId], references: [id])
  ProveedorProducto    ProveedorProducto[]
  Promocion            Promocion[]            @relation("PromocionProducto")

  @@index([codigoBarras])
  @@index([codigoInterno])
  @@index([nombre])
}

model Promocion {
  id           Int              @id @default(autoincrement())
  nombre       String
  tipo         TipoPromocion
  alcance      AlcancePromocion
  descuento    Decimal          @db.Decimal(5, 2)
  activa       Boolean          @default(true)
  fechaInicio  DateTime
  fechaFin     DateTime
  sucursalId   Int
  categoriaId  Int?
  notas        String?
  creadaEn     DateTime         @default(now())
  DetalleVenta DetalleVenta[]
  Categoria    Categoria?       @relation(fields: [categoriaId], references: [id])
  Sucursal     Sucursal         @relation(fields: [sucursalId], references: [id])
  Producto     Producto[]       @relation("PromocionProducto")

  @@index([activa])
  @@index([fechaFin])
  @@index([fechaInicio])
}

model Proveedor {
  id                Int                 @id @default(autoincrement())
  nombreOficial     String              @unique
  alias             String?             @unique
  telefono          String?
  celular           String?
  email             String?
  activo            Boolean             @default(true)
  creadoEn          DateTime            @default(now())
  OrdenCompra       OrdenCompra[]
  ProveedorProducto ProveedorProducto[]

  @@index([alias])
  @@index([nombreOficial])
}

model ProveedorProducto {
  id              Int       @id @default(autoincrement())
  proveedorId     Int
  productoId      Int
  codigoProveedor String?
  precioCosto     Decimal   @db.Decimal(10, 2)
  activo          Boolean   @default(true)
  actualizadoEn   DateTime
  Producto        Producto  @relation(fields: [productoId], references: [id])
  Proveedor       Proveedor @relation(fields: [proveedorId], references: [id])

  @@unique([proveedorId, productoId])
}

model Sucursal {
  id                   Int                    @id @default(autoincrement())
  nombre               String
  direccion            String?
  telefono             String?
  codigoPostal         String
  activa               Boolean                @default(true)
  creadaEn             DateTime               @default(now())
  AlertaStock          AlertaStock[]
  Auditoria            Auditoria[]
  Bitacora             Bitacora[]
  Cotizacion           Cotizacion[]
  InventarioSucursal   InventarioSucursal[]
  MovimientoInventario MovimientoInventario[]
  OrdenCompra          OrdenCompra[]
  Pedido               Pedido[]
  Promocion            Promocion[]
  TurnoCaja            TurnoCaja[]
  Usuario              Usuario[]
  Venta                Venta[]
}

model TurnoCaja {
  id                     Int                    @id @default(autoincrement())
  sucursalId             Int
  usuarioId              Int
  montoInicial           Decimal                @db.Decimal(10, 2)
  montoFinalDeclarado    Decimal?               @db.Decimal(10, 2)
  montoCalculado         Decimal?               @db.Decimal(10, 2)
  diferencia             Decimal?               @db.Decimal(10, 2)
  abierto                Boolean                @default(true)
  abiertaEn              DateTime               @default(now())
  cerradaEn              DateTime?
  reporteStockUrl        String?
  reporteStockEstado     EstadoReporteStock?
  reporteStockGeneradoEn DateTime?
  notasCierre            String?
  AbonoBitacora          AbonoBitacora[]
  AlertaStock            AlertaStock[]
  MovimientoCaja         MovimientoCaja[]
  MovimientoInventario   MovimientoInventario[]
  Sucursal               Sucursal               @relation(fields: [sucursalId], references: [id])
  Usuario                Usuario                @relation(fields: [usuarioId], references: [id])
  Venta                  Venta[]

  @@index([cerradaEn])
  @@index([sucursalId, abierto])
}

model Usuario {
  id                   Int                    @id @default(autoincrement())
  nombre               String
  username             String                 @unique
  passwordHash         String
  rol                  Rol
  activo               Boolean                @default(true)
  creadoEn             DateTime               @default(now())
  sucursalId           Int?
  pin                  String?
  tienePin             Boolean                @default(false)
  AbonoBitacora        AbonoBitacora[]
  AbonoCompra          AbonoCompra[]
  Auditoria            Auditoria[]
  Bitacora             Bitacora[]
  Cotizacion           Cotizacion[]
  Devolucion           Devolucion[]
  MovimientoInventario MovimientoInventario[]
  OrdenCompra          OrdenCompra[]
  Pedido               Pedido[]
  TurnoCaja            TurnoCaja[]
  Sucursal             Sucursal?              @relation(fields: [sucursalId], references: [id])
  Venta                Venta[]
}

model Venta {
  id                 Int               @id @default(autoincrement())
  folio              String            @unique
  sucursalId         Int
  usuarioId          Int
  clienteId          Int?
  turnoId            Int
  metodoPago         MetodoPago
  subtotal           Decimal           @db.Decimal(10, 2)
  descuento          Decimal           @default(0) @db.Decimal(10, 2)
  total              Decimal           @db.Decimal(10, 2)
  estadoPago         EstadoPago        @default(PAGADA)
  montoAbonado       Decimal           @default(0) @db.Decimal(10, 2)
  saldoPendiente     Decimal           @default(0) @db.Decimal(10, 2)
  montoPagado        Decimal           @default(0) @db.Decimal(10, 2)
  cambio             Decimal           @default(0) @db.Decimal(10, 2)
  estado             EstadoVenta       @default(COMPLETADA)
  tokenQr            String            @unique
  facturaEstado      EstadoFactura     @default(DISPONIBLE)
  facturaLimite      DateTime          @default(now())
  clienteRazonSocial String?
  clienteRFC         String?
  notas              String?
  creadaEn           DateTime          @default(now())
  desglosePagos      Json?
  DetalleBitacora    DetalleBitacora[]
  DetalleVenta       DetalleVenta[]
  Devolucion         Devolucion[]
  FacturaCfdi        FacturaCfdi?
  Cliente            Cliente?          @relation(fields: [clienteId], references: [id])
  Sucursal           Sucursal          @relation(fields: [sucursalId], references: [id])
  TurnoCaja          TurnoCaja         @relation(fields: [turnoId], references: [id])
  Usuario            Usuario           @relation(fields: [usuarioId], references: [id])

  @@index([clienteId])
  @@index([creadaEn])
  @@index([sucursalId])
  @@index([turnoId])
  @@index([usuarioId])
}

enum AlcancePromocion {
  PRODUCTO
  CATEGORIA
  SUCURSAL
}

enum EstadoAlerta {
  PENDIENTE
  VISTA
  RESUELTA
}

enum EstadoBitacora {
  ABIERTA
  PAUSADA
  CERRADA_VENTA
  CERRADA_INTERNA
}

enum EstadoCotizacion {
  PENDIENTE
  CONVERTIDA
  VENCIDA
  CANCELADA
}

enum EstadoFactura {
  DISPONIBLE
  FACTURADA
  VENCIDA
  CANCELADA
  BLOQUEADA
  PENDIENTE_TIMBRADO
  TIMBRADA
}

enum EstadoOrdenCompra {
  ENVIADO
  RECIBIDO_PARCIAL
  RECIBIDO
  CANCELADO
}

enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADA
  ATRASADA
}

enum EstadoPedido {
  BORRADOR
  PENDIENTE
  ACTIVO
  BLOQUEADO
  EJECUTADO
  CANCELADO
}

enum EstadoReporteStock {
  PENDIENTE
  GENERANDO
  LISTO
  ERROR
  EXPIRADO
}

