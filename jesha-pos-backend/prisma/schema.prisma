generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ══════════════════════════════════════════════════════════════════
//  ENUMS
// ══════════════════════════════════════════════════════════════════

enum Rol {
  SUPERADMIN
  ADMIN_SUCURSAL
  EMPLEADO
  PRECIOS
}

enum EstadoVenta {
  COMPLETADA
  CANCELADA
}

enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADA
  ATRASADA
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO
  TRANSFERENCIA
}

enum EstadoCotizacion {
  PENDIENTE
  CONVERTIDA
  VENCIDA
  CANCELADA
}

enum EstadoPedido {
  BORRADOR
  PENDIENTE
  ACTIVO
  BLOQUEADO
  EJECUTADO
  CANCELADO
}

enum EstadoOrdenCompra {
  ENVIADO
  RECIBIDO_PARCIAL
  RECIBIDO
  CANCELADO
}

enum EstadoFactura {
  DISPONIBLE
  FACTURADA
  VENCIDA
  CANCELADA
  BLOQUEADA
}

enum TipoMovimientoInventario {
  ENTRADA_COMPRA
  SALIDA_VENTA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
  DEVOLUCION_ENTRADA
  DEVOLUCION_SALIDA
}

enum TipoMovimientoCaja {
  APERTURA
  VENTA
  DEVOLUCION
  AJUSTE
  CIERRE
}

enum TipoPromocion {
  BUEN_FIN
  HOT_SALE
  MANUAL
}

enum AlcancePromocion {
  PRODUCTO
  CATEGORIA
  SUCURSAL
}

enum EstadoAlerta {
  PENDIENTE
  VISTA
  RESUELTA
}

// ══════════════════════════════════════════════════════════════════
//  SUCURSAL
// ══════════════════════════════════════════════════════════════════

model Sucursal {
  id           Int      @id @default(autoincrement())
  nombre       String
  direccion    String?
  telefono     String?
  codigoPostal String
  activa       Boolean  @default(true)
  creadaEn     DateTime @default(now())

  usuarios      Usuario[]
  inventarios   InventarioSucursal[]
  ventas        Venta[]
  cotizaciones  Cotizacion[]
  pedidos       Pedido[]
  ordenesCompra OrdenCompra[]
  turnosCaja    TurnoCaja[]
  promociones   Promocion[]
  alertasStock  AlertaStock[]
  auditorias    Auditoria[]
}

// ══════════════════════════════════════════════════════════════════
//  USUARIO
// ══════════════════════════════════════════════════════════════════

model Usuario {
  id           Int      @id @default(autoincrement())
  nombre       String
  username     String   @unique
  passwordHash String
  rol          Rol
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  sucursalId   Int?
  sucursal     Sucursal? @relation(fields: [sucursalId], references: [id])

  ventas         Venta[]
  cotizaciones   Cotizacion[]
  turnosCaja     TurnoCaja[]
  pedidos        Pedido[]
  movimientos    MovimientoInventario[]
  devoluciones   Devolucion[]           // ← AGREGADO
  auditorias     Auditoria[]
}

// ══════════════════════════════════════════════════════════════════
//  CLIENTE
// ══════════════════════════════════════════════════════════════════

model Cliente {
  id                 Int      @id @default(autoincrement())
  nombre             String
  apodo              String?
  rfc                String?  @unique
  telefono           String?
  email              String?  @unique
  codigoPostalFiscal String?
  regimenFiscal      String?
  razonSocial        String?
  usoCfdi            String?
  tipo               String   @default("REGULAR")

  limiteCredito      Decimal  @default(0) @db.Decimal(12,2)
  saldoPendiente     Decimal  @default(0) @db.Decimal(12,2)
  totalCreditoUsado  Decimal  @default(0) @db.Decimal(12,2)

  activo             Boolean  @default(true)
  notas              String?
  creadoEn           DateTime @default(now())

  ventas       Venta[]
  cotizaciones Cotizacion[]
  pedidos      Pedido[]
  facturas     FacturaCfdi[]

  @@index([nombre])
  @@index([rfc])
  @@index([email])
}

// ══════════════════════════════════════════════════════════════════
//  CATÁLOGO
// ══════════════════════════════════════════════════════════════════

model Departamento {
  id        Int      @id @default(autoincrement())
  nombre    String   @unique
  icono     String?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  categorias Categoria[]
}

model Categoria {
  id             Int      @id @default(autoincrement())
  departamentoId Int
  nombre         String
  descripcion    String?
  creadoEn       DateTime @default(now())

  departamento Departamento @relation(fields: [departamentoId], references: [id])
  productos    Producto[]
  promociones  Promocion[]

  @@unique([departamentoId, nombre])
}

// ══════════════════════════════════════════════════════════════════
//  PROVEEDORES
// ══════════════════════════════════════════════════════════════════

model Proveedor {
  id            Int      @id @default(autoincrement())
  nombreOficial String   @unique
  alias         String?  @unique
  telefono      String?
  celular       String?
  email         String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())

  productos     ProveedorProducto[]
  ordenesCompra OrdenCompra[]

  @@index([nombreOficial])
  @@index([alias])
}

model ProveedorProducto {
  id              Int      @id @default(autoincrement())
  proveedorId     Int
  productoId      Int
  codigoProveedor String?
  precioCosto     Decimal  @db.Decimal(10, 2)
  activo          Boolean  @default(true)
  actualizadoEn   DateTime @updatedAt  // ← AGREGADO

  proveedor Proveedor @relation(fields: [proveedorId], references: [id])
  producto  Producto  @relation(fields: [productoId], references: [id])

  @@unique([proveedorId, productoId])
}

// ══════════════════════════════════════════════════════════════════
//  PRODUCTO
// ══════════════════════════════════════════════════════════════════

model Producto {
  id             Int      @id @default(autoincrement())
  nombre         String
  codigoInterno  String   @unique
  codigoBarras   String?  @unique
  descripcion    String?

  imagenUrl      String?
  imagenOriginal String?

  precioBase     Decimal  @db.Decimal(10, 2)
  costo          Decimal? @db.Decimal(10, 2)
  costoPromedio  Decimal? @db.Decimal(10, 2)

  precioMayoreo      Decimal? @db.Decimal(10, 2)
  cantidadMinMayoreo Int?     @default(10)
  aplicaMayoreo      Boolean  @default(false)

  unidadCompra     String?
  unidadVenta      String?
  factorConversion Decimal? @db.Decimal(10, 4)

  claveSat  String?
  unidadSat String?

  esGranel Boolean  @default(false)
  margen   Decimal? @db.Decimal(5, 2)

  categoriaId Int

  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  categoria           Categoria            @relation(fields: [categoriaId], references: [id])
  inventarios         InventarioSucursal[]
  detallesVenta       DetalleVenta[]
  detallesCotizacion  DetalleCotizacion[]
  detallesOrdenCompra DetalleOrdenCompra[]
  detallesPedido      DetallePedido[]
  detallesDevolucion  DetalleDevolucion[]  // ← AGREGADO
  proveedores         ProveedorProducto[]
  promociones         Promocion[]          @relation("PromocionProducto")
  movimientos         MovimientoInventario[]
  alertasStock        AlertaStock[]        // ← AGREGADO

  @@index([nombre])
  @@index([codigoInterno])
  @@index([codigoBarras])
}

// ══════════════════════════════════════════════════════════════════
//  INVENTARIO
// ══════════════════════════════════════════════════════════════════

model InventarioSucursal {
  id                Int      @id @default(autoincrement())
  productoId        Int
  sucursalId        Int
  stockActual       Int      @default(0)
  stockMinimoAlerta Int      @default(5)
  stockMaximo       Int?
  actualizadoEn     DateTime @updatedAt

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([productoId, sucursalId])
  @@index([sucursalId])
  @@index([stockActual])
}

model MovimientoInventario {
  id           Int                      @id @default(autoincrement())
  productoId   Int
  sucursalId   Int
  usuarioId    Int?
  tipo         TipoMovimientoInventario
  cantidad     Int
  stockAntes   Int
  stockDespues Int
  referencia   String?
  notas        String?
  creadoEn     DateTime @default(now())

  producto Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  usuario  Usuario?  @relation(fields: [usuarioId], references: [id])

  @@index([productoId])
  @@index([sucursalId])
  @@index([usuarioId])
  @@index([tipo])
  @@index([creadoEn])
}

model AlertaStock {
  id          Int          @id @default(autoincrement())
  productoId  Int
  sucursalId  Int
  stockActual Int
  stockMinimo Int
  estado      EstadoAlerta @default(PENDIENTE)
  creadaEn    DateTime     @default(now())
  vistaEn     DateTime?
  resueltaEn  DateTime?

  producto Producto @relation(fields: [productoId], references: [id])  // ← AGREGADO
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([productoId, sucursalId])
  @@index([productoId])  // ← AGREGADO
  @@index([sucursalId])
  @@index([estado])
}

// ══════════════════════════════════════════════════════════════════
//  CAJA
// ══════════════════════════════════════════════════════════════════

model TurnoCaja {
  id                  Int       @id @default(autoincrement())
  sucursalId          Int
  usuarioId           Int
  montoInicial        Decimal   @db.Decimal(10, 2)
  montoFinalDeclarado Decimal?  @db.Decimal(10, 2)
  montoCalculado      Decimal?  @db.Decimal(10, 2)
  diferencia          Decimal?  @db.Decimal(10, 2)
  abierto             Boolean   @default(true)
  abiertaEn           DateTime  @default(now())
  cerradaEn           DateTime?

  sucursal    Sucursal         @relation(fields: [sucursalId], references: [id])
  usuario     Usuario          @relation(fields: [usuarioId], references: [id])
  ventas      Venta[]
  movimientos MovimientoCaja[]

  @@index([sucursalId, abierto])  // ← AGREGADO: query más frecuente del POS
}

model MovimientoCaja {
  id         Int                @id @default(autoincrement())
  turnoId    Int
  tipo       TipoMovimientoCaja
  monto      Decimal            @db.Decimal(10, 2)
  metodoPago MetodoPago?
  referencia String?
  notas      String?
  creadoEn   DateTime           @default(now())

  turno TurnoCaja @relation(fields: [turnoId], references: [id], onDelete: Cascade)

  @@index([turnoId])  // ← AGREGADO: usado en cierre de turno
}

// ══════════════════════════════════════════════════════════════════
//  VENTAS
// ══════════════════════════════════════════════════════════════════

model Venta {
  id         Int        @id @default(autoincrement())
  folio      String     @unique
  sucursalId Int
  usuarioId  Int
  clienteId  Int?
  turnoId    Int
  metodoPago MetodoPago

  subtotal  Decimal @db.Decimal(10, 2)
  descuento Decimal @default(0) @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2)

  // Crédito — sincronizar siempre con Cliente.saldoPendiente en el controller
  estadoPago     EstadoPago @default(PAGADA)
  montoAbonado   Decimal    @default(0) @db.Decimal(10, 2)
  saldoPendiente Decimal    @default(0) @db.Decimal(10, 2)

  estado        EstadoVenta   @default(COMPLETADA)
  tokenQr       String        @unique @default(uuid())
  facturaEstado EstadoFactura @default(DISPONIBLE)
  facturaLimite DateTime      @default(now())  // ← CORREGIDO: evita error en insert

  clienteRazonSocial String?
  clienteRFC         String?

  notas    String?
  creadaEn DateTime @default(now())

  sucursal     Sucursal       @relation(fields: [sucursalId], references: [id])
  usuario      Usuario        @relation(fields: [usuarioId], references: [id])
  cliente      Cliente?       @relation(fields: [clienteId], references: [id])
  turno        TurnoCaja      @relation(fields: [turnoId], references: [id])
  detalles     DetalleVenta[]
  devoluciones Devolucion[]
  factura      FacturaCfdi?

  @@index([clienteId])
  @@index([usuarioId])
  @@index([sucursalId])
  @@index([turnoId])    // ← AGREGADO: usado en corte de caja
  @@index([creadaEn])
}

model DetalleVenta {
  id             Int     @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  descuento      Decimal @default(0) @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)
  promocionId    Int?

  venta     Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto  Producto   @relation(fields: [productoId], references: [id])
  promocion Promocion? @relation(fields: [promocionId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
//  DEVOLUCIONES
// ══════════════════════════════════════════════════════════════════

model Devolucion {
  id                  Int      @id @default(autoincrement())
  ventaId             Int
  sucursalId          Int
  usuarioId           Int
  motivo              String
  reintegraInventario Boolean  @default(true)
  tipoReembolso       String
  montoReembolso      Decimal  @db.Decimal(10, 2)
  notas               String?
  creadaEn            DateTime @default(now())

  venta    Venta               @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  usuario  Usuario             @relation(fields: [usuarioId], references: [id])  // ← AGREGADO
  detalles DetalleDevolucion[]
}

model DetalleDevolucion {
  id             Int      @id @default(autoincrement())
  devolucionId   Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2)
  creadoEn       DateTime @default(now())

  devolucion Devolucion @relation(fields: [devolucionId], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [productoId], references: [id])  // ← AGREGADO
}

// ══════════════════════════════════════════════════════════════════
//  COTIZACIONES
// ══════════════════════════════════════════════════════════════════

model Cotizacion {
  id         Int              @id @default(autoincrement())
  folio      String           @unique
  sucursalId Int
  usuarioId  Int
  clienteId  Int?
  total      Decimal          @db.Decimal(10, 2)
  estado     EstadoCotizacion @default(PENDIENTE)
  venceEn    DateTime?
  notas      String?
  creadaEn   DateTime         @default(now())

  sucursal Sucursal            @relation(fields: [sucursalId], references: [id])
  usuario  Usuario             @relation(fields: [usuarioId], references: [id])
  cliente  Cliente?            @relation(fields: [clienteId], references: [id])
  detalles DetalleCotizacion[]

  @@index([estado])    // ← AGREGADO
  @@index([clienteId]) // ← AGREGADO
}

model DetalleCotizacion {
  id             Int     @id @default(autoincrement())
  cotizacionId   Int
  productoId     Int
  cantidad       Int
  precioUnitario Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto   Producto   @relation(fields: [productoId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
//  PEDIDOS
// ══════════════════════════════════════════════════════════════════

model Pedido {
  id            Int          @id @default(autoincrement())
  folio         String       @unique
  sucursalId    Int
  usuarioId     Int
  clienteId     Int?
  estado        EstadoPedido @default(BORRADOR)
  totalEstimado Decimal      @db.Decimal(10, 2)
  motivoBloqueo String?
  notas         String?
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt

  sucursal Sucursal        @relation(fields: [sucursalId], references: [id])
  usuario  Usuario         @relation(fields: [usuarioId], references: [id])
  cliente  Cliente?        @relation(fields: [clienteId], references: [id])
  detalles DetallePedido[]
}

model DetallePedido {
  id             Int     @id @default(autoincrement())
  pedidoId       Int
  productoId     Int
  cantidad       Int
  precioAcordado Decimal @db.Decimal(10, 2)
  subtotal       Decimal @db.Decimal(10, 2)

  pedido   Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
//  COMPRAS
// ══════════════════════════════════════════════════════════════════

model OrdenCompra {
  id            Int               @id @default(autoincrement())
  folio         String            @unique
  sucursalId    Int
  proveedorId   Int
  estado        EstadoOrdenCompra @default(ENVIADO)
  totalEstimado Decimal           @db.Decimal(10, 2)
  totalRecibido Decimal           @default(0) @db.Decimal(10, 2)
  notas         String?
  creadaEn      DateTime          @default(now())
  recibidaEn    DateTime?

  sucursal  Sucursal             @relation(fields: [sucursalId], references: [id])
  proveedor Proveedor            @relation(fields: [proveedorId], references: [id])
  detalles  DetalleOrdenCompra[]
}

model DetalleOrdenCompra {
  id               Int     @id @default(autoincrement())
  ordenCompraId    Int
  productoId       Int
  cantidadPedida   Int
  cantidadRecibida Int     @default(0)
  precioCosto      Decimal @db.Decimal(10, 2)
  subtotalPedido   Decimal @db.Decimal(10, 2)
  subtotalRecibido Decimal @default(0) @db.Decimal(10, 2)

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  producto    Producto    @relation(fields: [productoId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
//  PROMOCIONES
// ══════════════════════════════════════════════════════════════════

model Promocion {
  id          Int              @id @default(autoincrement())
  nombre      String
  tipo        TipoPromocion
  alcance     AlcancePromocion
  descuento   Decimal          @db.Decimal(5, 2)
  activa      Boolean          @default(true)
  fechaInicio DateTime
  fechaFin    DateTime
  sucursalId  Int
  categoriaId Int?
  notas       String?
  creadaEn    DateTime         @default(now())

  sucursal      Sucursal       @relation(fields: [sucursalId], references: [id])
  categoria     Categoria?     @relation(fields: [categoriaId], references: [id])
  productos     Producto[]     @relation("PromocionProducto")
  detallesVenta DetalleVenta[]

  @@index([activa])
  @@index([fechaInicio])
  @@index([fechaFin])
}

// ══════════════════════════════════════════════════════════════════
//  FACTURACIÓN CFDI
// ══════════════════════════════════════════════════════════════════

model FacturaCfdi {
  id              Int           @id @default(autoincrement())
  ventaId         Int           @unique
  clienteId       Int
  rfcReceptor     String
  nombreReceptor  String
  cpReceptor      String
  regimenFiscal   String
  usoCfdi         String
  lugarExpedicion String
  subtotal        Decimal       @db.Decimal(10, 2)
  iva             Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  folioFiscal     String?
  xmlUrl          String?
  pdfUrl          String?
  estado          EstadoFactura @default(FACTURADA)
  timbradaEn      DateTime?
  creadaEn        DateTime      @default(now())

  venta   Venta   @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
//  AUDITORÍA
// ══════════════════════════════════════════════════════════════════

model Auditoria {
  id           Int      @id @default(autoincrement())
  usuarioId    Int?
  sucursalId   Int?
  accion       String
  modulo       String
  referencia   String?
  valorAntes   Json?
  valorDespues Json?
  ip           String?
  creadoEn     DateTime @default(now())

  usuario  Usuario?  @relation(fields: [usuarioId], references: [id])
  sucursal Sucursal? @relation(fields: [sucursalId], references: [id])

  @@index([usuarioId])
  @@index([sucursalId])
  @@index([modulo])
  @@index([accion])
  @@index([creadoEn])
}
