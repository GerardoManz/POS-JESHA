{
  "apiUrl": "https://jesha-pos-api.onrender.com",
  "printer": {
    "interface": "printer:POS58 Printer",
    "width": 32,
    "codepage": "PC437",
    "cutMode": "full",
    "feedLinesAfterPrint": 4,
    "printLogo": true,
    "logoUrl": "https://res.cloudinary.com/dabyfymjd/image/upload/q_auto/f_auto/v1779317658/logo-jesha_hmlble.png",
    "openCashDrawerEnabled": true
  },
  "pollIntervalMs": 2000,
  "networkTimeoutMs": 8000,
  "skipOldJobs": true,
  "oldJobThresholdMinutes": 120,
  "resetOnStart": false
}
